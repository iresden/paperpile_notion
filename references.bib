@ARTICLE{Gans1983-mz,
  title     = "Neural crest and the origin of vertebrates: a new head",
  author    = "Gans, C and Northcutt, R G",
  journal   = "Science",
  publisher = "American Association for the Advancement of Science (AAAS)",
  volume    =  220,
  number    =  4594,
  pages     = "268--273",
  abstract  = "Most of the morphological and functional differences between
               vertebrates and other chordates occur in the head and are derived
               embryologically from muscularized hypomere, neural crest, and
               epidermal (neurogenic) placodes. In the head, the neural crest
               functions as mesoderm and forms connective, skeletal, and
               muscular tissue. Both the neural crest and the epidermal placodes
